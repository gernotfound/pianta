rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidSettings(data) {
      return (data.title == null || (data.title is string && data.title.size() <= 200))
        && (data.notes == null || (data.notes is string && data.notes.size() <= 5000));
    }

    function isValidPlant(data) {
      return data.keys().hasAll(['ownerId', 'name'])
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && (data.id == null || data.id is string)
        && (data.createdAt == null || data.createdAt is number)
        && (data.updatedAt == null || data.updatedAt is number)
        && (data.scientific == null || (data.scientific is string && data.scientific.size() <= 100))
        && (data.price == null || data.price is number)
        && (data.origin == null || data.origin is string)
        && (data.autofertile == null || data.autofertile is string)
        && (data.sowingDate == null || data.sowingDate is string)
        && (data.geneticFidelity == null || data.geneticFidelity is string)
        && (data.placement == null || data.placement is string)
        && (data.potSize == null || data.potSize is number)
        && (data.soil == null || data.soil is string)
        && (data.phMin == null || data.phMin is number)
        && (data.phMax == null || data.phMax is number)
        && (data.vendor == null || data.vendor is string)
        && (data.location == null || data.location is string)
        && (data.lat == null || data.lat is number)
        && (data.lng == null || data.lng is number)
        && (data.photo == null || data.photo is string)
        && (data.fruitPhoto == null || data.fruitPhoto is string)
        && (data.mother == null || data.mother is string)
        && (data.father == null || data.father is string)
        && (data.minTemp == null || data.minTemp is number)
        && (data.maxTemp == null || data.maxTemp is number)
        && (data.notes == null || data.notes is string)
        && (data.isArchived == null || data.isArchived is bool)
        && (data.archiveDate == null || data.archiveDate is string)
        && (data.archiveReason == null || data.archiveReason is string);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['date', 'type'])
        && data.date is string && data.date.size() <= 50
        && data.type is string && data.type.size() <= 50
        && (data.id == null || data.id is string)
        && (data.height == null || data.height is number)
        && (data.harvest == null || data.harvest is string)
        && (data.ph == null || data.ph is number)
        && (data.placement == null || data.placement is string)
        && (data.potSize == null || data.potSize is number)
        && (data.graftName == null || data.graftName is string)
        && (data.note == null || data.note is string)
        && (data.photos == null || data.photos is list);
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['ownerId', 'date', 'cost'])
        && data.ownerId == request.auth.uid
        && data.date is string && data.date.size() <= 50
        && data.cost is number
        && (data.id == null || data.id is string)
        && (data.createdAt == null || data.createdAt is number)
        && (data.category == null || (data.category is string && data.category.size() <= 100))
        && (data.desc == null || (data.desc is string && data.desc.size() <= 500));
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['ownerId', 'name'])
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && (data.id == null || data.id is string)
        && (data.createdAt == null || data.createdAt is number)
        && (data.price == null || data.price is number)
        && (data.notes == null || data.notes is string)
        && (data.photo == null || data.photo is string);
    }

    match /users/{userId} {
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(settingId) && isValidSettings(incoming());
        allow update: if isOwner(userId) && isValidId(settingId) && isValidSettings(incoming());
      }

      match /plants/{plantId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(plantId) && isValidPlant(incoming());
        allow update: if isOwner(userId) && isValidId(plantId) && isValidPlant(incoming()) && incoming().ownerId == existing().ownerId;
        allow delete: if isOwner(userId) && isValidId(plantId);

        match /logs/{logId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidId(logId) && isValidLog(incoming());
          allow update: if isOwner(userId) && isValidId(logId) && isValidLog(incoming());
          allow delete: if isOwner(userId) && isValidId(logId);
        }
      }

      match /expenses/{expenseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(expenseId) && isValidExpense(incoming());
        allow update: if isOwner(userId) && isValidId(expenseId) && isValidExpense(incoming()) && incoming().ownerId == existing().ownerId;
        allow delete: if isOwner(userId) && isValidId(expenseId);
      }

      match /wishlist/{wishlistId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(wishlistId) && isValidWishlistItem(incoming());
        allow update: if isOwner(userId) && isValidId(wishlistId) && isValidWishlistItem(incoming()) && incoming().ownerId == existing().ownerId;
        allow delete: if isOwner(userId) && isValidId(wishlistId);
      }
    }
  }
}
