{
  "entities": {
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "Plant": {
      "title": "Plant",
      "description": "A plant entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "ownerId": { "type": "string" },
        "name": { "type": "string", "maxLength": 100 },
        "scientific": { "type": "string", "maxLength": 100 },
        "price": { "type": "number" },
        "origin": { "type": "string" },
        "autofertile": { "type": "string" },
        "sowingDate": { "type": "string" },
        "geneticFidelity": { "type": "string" },
        "placement": { "type": "string" },
        "potSize": { "type": "number" },
        "soil": { "type": "string" },
        "phMin": { "type": "number" },
        "phMax": { "type": "number" },
        "vendor": { "type": "string" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "photo": { "type": "string" },
        "fruitPhoto": { "type": "string" },
        "mother": { "type": "string" },
        "father": { "type": "string" },
        "minTemp": { "type": "number" },
        "maxTemp": { "type": "number" },
        "notes": { "type": "string" },
        "isArchived": { "type": "boolean" },
        "archiveDate": { "type": "string" },
        "archiveReason": { "type": "string" }
      },
      "required": ["ownerId", "name"]
    },
    "Log": {
      "title": "Log",
      "description": "Diary log entry for a plant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "maxLength": 50 },
        "height": { "type": "number" },
        "harvest": { "type": "string" },
        "ph": { "type": "number" },
        "placement": { "type": "string" },
        "potSize": { "type": "number" },
        "graftName": { "type": "string" },
        "note": { "type": "string" },
        "photos": { "type": "array" }
      }
    },
    "Expense": {
      "title": "Expense",
      "description": "A garden expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "number" },
        "ownerId": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string", "maxLength": 100 },
        "desc": { "type": "string", "maxLength": 500 },
        "cost": { "type": "number" }
      },
      "required": ["ownerId", "date", "cost"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "Item in the wishlist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "number" },
        "ownerId": { "type": "string" },
        "name": { "type": "string", "maxLength": 200 },
        "price": { "type": "number" },
        "notes": { "type": "string" },
        "photo": { "type": "string" }
      },
      "required": ["ownerId", "name"]
    }
  },
  "firestore": {
    "users/{userId}/settings/{settingId}": {
      "schema": { "$ref": "#/entities/SystemSettings" },
      "description": "User specific settings"
    },
    "users/{userId}/plants/{plantId}": {
      "schema": { "$ref": "#/entities/Plant" },
      "description": "User's plants"
    },
    "users/{userId}/plants/{plantId}/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "Logs for a specific plant"
    },
    "users/{userId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "User's expenses"
    },
    "users/{userId}/wishlist/{wishlistId}": {
      "schema": { "$ref": "#/entities/WishlistItem" },
      "description": "User's wishlist items"
    }
  }
}
